XF86MonBrightness{Up,Down} 
    brightnessctl -d 'intel_backlight' set {+5%,5-%}

XF86Audio{Raise,Lower}Volume
    pactl set-sink-volume @DEFAULT_SINK@ {+5%,-5%}

XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle

XF86TouchpadToggle
    toggle-touchpad

super + L
    betterlockscreen -l

super + s
    screenshot.sh
