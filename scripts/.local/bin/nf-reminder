#!/bin/zsh

filename=$0:t
for pid in $(pgrep -x $filename)
do
    if [ "$pid" != "$$" ]
    then
        echo "$filename : Process is already running with PID $pid"
        exit 1
    fi
done

echo running...

days=$(( ($(date +%s) - 1671735642) / 86400 ))
while true
do
    notify-send "Day $days" -t 750
    sleep 1h
done
